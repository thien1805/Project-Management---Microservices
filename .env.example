# Postgres (auth)
AUTH_POSTGRES_USER=postgres
AUTH_POSTGRES_PASSWORD=your_auth_postgres_password
AUTH_POSTGRES_DB=auth_db
AUTH_POSTGRES_HOST_PORT=5433

# Postgres (project/task)
TASK_POSTGRES_USER=postgres
TASK_POSTGRES_PASSWORD=your_task_postgres_password
TASK_POSTGRES_DB=task_management
TASK_POSTGRES_HOST_PORT=5432

# Postgres (notification)
NOTIFICATION_POSTGRES_USER=postgres
NOTIFICATION_POSTGRES_PASSWORD=your_notification_postgres_password
NOTIFICATION_POSTGRES_DB=notification_db
NOTIFICATION_POSTGRES_HOST_PORT=5434

# Auth service
AUTH_SERVICE_PORT=3001
AUTH_HOST_PORT=3001
AUTH_DB_HOST=postgres-auth
AUTH_DB_PORT=5432
AUTH_DB_NAME=auth_db
AUTH_DB_PASSWORD=your_auth_postgres_password
AUTH_JWT_SECRET=replace_with_strong_jwt_secret
AUTH_JWT_EXPIRES=1h

# Project/Task service
PROJECT_SERVICE_PORT=3000
PROJECT_HOST_PORT=3010
PROJECT_DB_HOST=postgres-task
PROJECT_DB_PORT=5432
PROJECT_DB_NAME=task_management
PROJECT_DB_USER=postgres
PROJECT_DB_PASSWORD=your_task_postgres_password
PROJECT_NOTIFICATION_ENABLED=true
PROJECT_NOTIFICATION_URL=http://notification:3002/api/notifications

# Notification service
NOTIFICATION_SERVICE_PORT=3002
NOTIFICATION_HOST_PORT=3002
NOTIFICATION_DB_HOST=postgres-notification
NOTIFICATION_DB_PORT=5432
NOTIFICATION_DB_NAME=notification_db
NOTIFICATION_DB_USER=postgres
NOTIFICATION_DB_PASSWORD=your_notification_postgres_password

# Frontend
FRONTEND_NODE_ENV=production
FRONTEND_SERVICE_PORT=3003
FRONTEND_HOST_PORT=3003
FRONTEND_AUTH_SERVICE_URL=http://localhost:3001
FRONTEND_TASK_SERVICE_URL=http://localhost:3010
FRONTEND_NOTIFICATION_SERVICE_URL=http://localhost:3002
